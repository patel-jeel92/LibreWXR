# LibreWXR Configuration
# Copy this file to .env and adjust values as needed.
# All settings have sensible defaults — you only need to set what you want to change.

# Public-facing URL used in the weather-maps.json metadata response.
# Set this to whatever URL clients will use to reach your instance.
LIBREWXR_PUBLIC_URL=http://localhost:8080

# Port the server listens on.
LIBREWXR_PORT=8080

# Maximum tile zoom level (0-12). Higher values allow more detail when zoomed in
# but use more memory for cached tiles. 12 is the max supported by the data source.
LIBREWXR_MAX_ZOOM=12

# How often (in seconds) to fetch new radar frames.
# 600s (10 min) is the default cadence, matching Rain Viewer. Frame timestamps
# are always aligned to clock boundaries (e.g. :00, :10, :20) regardless of
# when the server starts. IEM publishes every 5 min, so 300 is possible if you
# want higher temporal resolution at the cost of double the frames.
LIBREWXR_FETCH_INTERVAL=600

# Number of radar frames to keep in memory. Each frame is ~63 MB (USCOMP only)
# or ~96 MB with all regions enabled.
# At the default 10-min cadence: 12 frames = 2 hours, 18 = 3 hours, 24 = 4 hours.
# More frames = longer animation history.
LIBREWXR_MAX_FRAMES=12

# Coordinate cache size: max entries per coordinate LRU cache.
# Controls how many tile-coordinate mappings are kept in memory.
# These caches are the largest RAM consumer after frames — each entry is
# 0.5-2 MB depending on tile size. Lower values save significant RAM
# at the cost of occasional recomputation (~5-20ms per miss).
# With 6 internal caches, total worst case ≈ coord_cache_size × 6 × ~1 MB.
LIBREWXR_COORD_CACHE_SIZE=2048

# Maximum tile cache size in megabytes. The cache stores rendered tile images
# and evicts the oldest entries when this byte limit is reached.
# Higher = faster tile serving, lower = less RAM usage.
LIBREWXR_TILE_CACHE_MB=200

# Container memory limit in MB for the memory pressure monitor.
# 0 = auto-detect from cgroup (Docker) or fall back to system RAM.
# Set this explicitly if auto-detection doesn't work in your environment.
LIBREWXR_MEMORY_LIMIT_MB=0

# How often (in seconds) the memory pressure monitor checks RSS usage.
# Lower = more responsive to memory spikes, higher = less overhead.
LIBREWXR_MEMORY_PRESSURE_CHECK_INTERVAL=30

# Gaussian blur radius for tile smoothing (when smooth=1 in the tile URL).
# Higher = softer/smoother radar appearance. 0 = disable smoothing entirely.
# Recommended: 2.0-4.0. Rain Viewer uses roughly 3.0.
LIBREWXR_SMOOTH_RADIUS=2.0

# Minimum dBZ threshold to display. Pixels below this are made transparent.
# Filters out ground clutter and weak noise. dBZ scale: 5 = very light, 20 = light rain.
# Set to -32 to disable (show everything).
LIBREWXR_NOISE_FLOOR_DBZ=10.0

# Speckle filter: minimum number of non-zero neighbors (out of 8) a pixel must
# have to be kept. Removes isolated radar artifacts and ground clutter.
# 0 = disabled, 2 = light, 3 = moderate (recommended), 4+ = aggressive.
LIBREWXR_DESPECKLE_MIN_NEIGHBORS=3

# WebP encoding quality. 100 = lossless (best quality, larger files).
# 80 = lossy (visually identical for radar, ~3-4x smaller than PNG).
# Only affects tiles requested in WebP format; PNG tiles are unaffected.
LIBREWXR_WEBP_QUALITY=100

# Radar regions to fetch. Use a group alias or comma-separated region codes.
#
# Group aliases:
#   CONUS   - Continental US only (default, lightest)
#   US      - All US regions (CONUS + Alaska, Hawaii, Puerto Rico, Guam)
#   CANADA  - Canada (ECCC MSC GeoMet WMS)
#   EUROPE  - Europe (OPERA pan-European composite, ~155 radars, 24 countries)
#   ALL     - Every available region
#
# Individual regions (can mix with groups):
#   USCOMP  - Continental US (12200x5400 @ 0.005°, ~63 MB/frame)
#   AKCOMP  - Alaska (4000x1550 @ 0.01°, ~6 MB/frame)
#   HICOMP  - Hawaii (2000x1800 @ 0.005°, ~3.4 MB/frame)
#   PRCOMP  - Puerto Rico (1000x1000 @ 0.01°, ~1 MB/frame)
#   GUCOMP  - Guam (1000x1000 @ 0.0085°, ~1 MB/frame)
#   CACOMP  - Canada (3560x1720 @ 0.025°, ~6 MB/frame)
#   OPERA   - Europe (3800x4400 @ 1km LAEA, ~16 MB/frame)
#
# Examples:
#   LIBREWXR_ENABLED_REGIONS=CONUS          (just continental US)
#   LIBREWXR_ENABLED_REGIONS=US             (all US regions)
#   LIBREWXR_ENABLED_REGIONS=EUROPE         (Europe only)
#   LIBREWXR_ENABLED_REGIONS=CANADA         (Canada only)
#   LIBREWXR_ENABLED_REGIONS=CONUS,EUROPE   (continental US + Europe)
#   LIBREWXR_ENABLED_REGIONS=ALL            (everything)
LIBREWXR_ENABLED_REGIONS=CONUS

# Number of uvicorn worker processes. Each worker is a fully independent copy
# of LibreWXR with its own frame store, cache, and fetcher. More workers =
# better concurrency for simultaneous users, but each uses ~1.3 GB+ RAM
# (frames + tile cache). Scale workers first when handling more users.
#
# Scaling guide:
#   1       - Personal use / 1-5 users (~1.3 GB RAM)
#   2-4     - Small community / 5-50 users (~2.6-5.2 GB RAM)
#   4-8     - Medium traffic / 50-200 users (~5.2-10.4 GB RAM)
#   8+      - Large traffic / 200+ users (put nginx or a CDN in front too)
#
# Recommended: 1 worker per 2 CPU cores. For high traffic, a caching reverse
# proxy (nginx, CloudFlare) in front will help more than adding workers — tiles
# already set Cache-Control headers so any proxy can cache them automatically.
LIBREWXR_WORKERS=1

# Thread pool size for background tile cache warming. When a tile is requested,
# the warmer pre-renders that tile position for all other timestamps in the
# background so animation playback is smooth. This is a "nice to have"
# optimization — scale workers before increasing this.
# 4 is a good default; 6-8 on machines with many cores.
LIBREWXR_WARMER_THREADS=4

# Number of ECMWF IFS hourly timesteps to fetch for global fallback animation.
# 0 = auto (recommended): derives from LIBREWXR_MAX_FRAMES so ECMWF animation
# covers the same time window as radar. Formula: ceil(max_frames / 6) + 1.
# At the default 10-min cadence:
#   12 frames (2h) → 3 timesteps, 18 (3h) → 4, 24 (4h) → 5
# Set to a positive number to override. Each timestep adds ~13 MB RAM and
# ~1-2 seconds to fetch time. Set to 1 for a static single snapshot.
# When ECMWF interpolation is enabled, each hourly pair also generates
# 5 synthetic 10-min frames (~130 MB total for the interpolated set).
LIBREWXR_ECMWF_MAX_TIMESTEPS=0

# Enable optical-flow interpolation of ECMWF IFS hourly data to 10-minute
# frames. Uses dense motion vectors to animate precipitation movement between
# IFS hours, so the global fallback animates smoothly like real radar data
# instead of jumping hour-to-hour.
# Adds ~130 MB RAM (for synthetic frames) and ~5-10s compute per IFS fetch.
# Set to false to disable (IFS will snap to nearest hour, visually jumpier).
LIBREWXR_ECMWF_INTERPOLATION=true

# Enable precipitation nowcasting (EXPERIMENTAL). Extrapolates recent radar
# forward using optical flow and blends with ECMWF IFS forecast, providing
# 60 minutes of short-range precipitation forecast. The blend transitions
# smoothly from radar-weighted (near-term) to IFS-weighted (far-term), with
# spatial feathering at radar coverage boundaries to prevent hard seams.
# Quality varies: works best for steady, organized precipitation; less
# reliable for fast-developing convection or cell initiation/dissipation.
# Adds ~120 MB RAM per frame × nowcast_frames for extrapolated data.
LIBREWXR_NOWCAST_ENABLED=true

# Nowcast blend mode: controls how radar extrapolation and IFS forecast data
# are combined during the first 60 minutes of the nowcast window.
# Beyond 60 min, pure IFS is always used regardless of this setting.
#   "blended" - smooth transition from radar-heavy to IFS-heavy
#               (~87% radar at T+10 min, fading to ~30% radar at T+60 min)
#   "radar"   - (default) pure radar extrapolation for the first 60 min
#               (closest to Rain Viewer behavior; less reliable for initiation)
#   "ifs"     - pure IFS forecast for all nowcast frames (most spatially
#               consistent but misses fine detail from recent radar)
LIBREWXR_NOWCAST_BLEND_MODE=radar

# Number of nowcast frames to generate. Each frame covers one fetch interval
# (default 10 min). At 10-min cadence: 6 frames = 60 min forecast.
# More frames = longer forecast range but lower accuracy at the far end.
# Rain Viewer offered ~30 min free / 60 min paid, so 6 is a good default.
LIBREWXR_NOWCAST_FRAMES=6

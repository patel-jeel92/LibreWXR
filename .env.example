# LibreWXR Configuration
# Copy this file to .env and adjust values as needed.
# All settings have sensible defaults — you only need to set what you want to change.

# Public-facing URL used in the weather-maps.json metadata response.
# Set this to whatever URL clients will use to reach your instance.
LIBREWXR_PUBLIC_URL=http://localhost:8080

# Port the server listens on.
LIBREWXR_PORT=8080

# Maximum tile zoom level (0-12). Higher values allow more detail when zoomed in
# but use more memory for cached tiles. 12 is the max supported by the data source.
LIBREWXR_MAX_ZOOM=12

# How often (in seconds) to fetch new radar frames.
# 600s (10 min) is the default cadence, matching Rain Viewer. Frame timestamps
# are always aligned to clock boundaries (e.g. :00, :10, :20) regardless of
# when the server starts. IEM publishes every 5 min, so 300 is possible if you
# want higher temporal resolution at the cost of double the frames.
LIBREWXR_FETCH_INTERVAL=600

# Number of radar frames to keep in memory. Each frame is ~63 MB (USCOMP only)
# or ~96 MB with all regions enabled.
# At the default 10-min cadence: 12 frames = 2 hours, 18 = 3 hours, 24 = 4 hours.
# More frames = longer animation history.
LIBREWXR_MAX_FRAMES=12

# Coordinate cache size: max entries per coordinate LRU cache.
# Controls how many tile-coordinate mappings are kept in memory.
# These caches are the largest RAM consumer after frames — each entry is
# 0.5-2 MB depending on tile size. Lower values save significant RAM
# at the cost of occasional recomputation (~5-20ms per miss).
# With 6 internal caches, total worst case ≈ coord_cache_size × 6 × ~1 MB.
LIBREWXR_COORD_CACHE_SIZE=2048

# Maximum tile cache size in megabytes. The cache stores rendered tile images
# and evicts the oldest entries when this byte limit is reached.
# Higher = faster tile serving, lower = less RAM usage.
LIBREWXR_TILE_CACHE_MB=200

# Container memory limit in MB for the memory pressure monitor.
# 0 = auto-detect from cgroup (Docker) or fall back to system RAM.
# Set this explicitly if auto-detection doesn't work in your environment.
LIBREWXR_MEMORY_LIMIT_MB=0

# Docker container memory limit (used in docker-compose.yml).
# Adjust based on regions, frames, and workers. Some reference points:
#   ALL regions, MRMS source, 1 worker: ~7-9 GB
#   ALL regions, IEM source, 1 worker: ~7-8 GB
#   CONUS only, 1 worker: ~3-4 GB
# Default: 7G
#LIBREWXR_MEMORY=7G

# How often (in seconds) the memory pressure monitor checks RSS usage.
# Lower = more responsive to memory spikes, higher = less overhead.
LIBREWXR_MEMORY_PRESSURE_CHECK_INTERVAL=30

# Gaussian blur radius for tile smoothing (when smooth=1 in the tile URL).
# Higher = softer/smoother radar appearance. 0 = disable smoothing entirely.
# Recommended: 2.0-4.0. Rain Viewer uses roughly 3.0.
LIBREWXR_SMOOTH_RADIUS=2.0

# Minimum dBZ threshold to display. Pixels below this are made transparent.
# Filters out ground clutter and weak noise. dBZ scale: 5 = very light, 20 = light rain.
# Set to -32 to disable (show everything).
LIBREWXR_NOISE_FLOOR_DBZ=10.0

# Speckle filter: minimum number of non-zero neighbors (out of 8) a pixel must
# have to be kept. Removes isolated radar artifacts and ground clutter.
# 0 = disabled, 2 = light, 3 = moderate (recommended), 4+ = aggressive.
LIBREWXR_DESPECKLE_MIN_NEIGHBORS=3

# WebP encoding quality. 100 = lossless (best quality, larger files).
# 65 = lossy (visually identical for radar, ~4-6x smaller than PNG).
# Only affects tiles requested in WebP format; PNG tiles are unaffected.
LIBREWXR_WEBP_QUALITY=65

# Radar regions to fetch. Use a group alias or comma-separated region codes.
#
# Group aliases:
#   CONUS   - Continental US only (default, lightest)
#   US      - All US regions (CONUS + Alaska, Hawaii, Puerto Rico, Guam)
#   CANADA  - Canada (ECCC MSC GeoMet WMS)
#   EUROPE  - Europe (OPERA pan-European composite, ~155 radars, 24 countries)
#   ALL     - Every available region
#
# Individual regions (can mix with groups):
#   USCOMP  - Continental US (12200x5400 @ 0.005°, ~63 MB/frame)
#   AKCOMP  - Alaska (4000x1550 @ 0.01°, ~6 MB/frame)
#   HICOMP  - Hawaii (2000x1800 @ 0.005°, ~3.4 MB/frame)
#   PRCOMP  - Puerto Rico (1000x1000 @ 0.01°, ~1 MB/frame)
#   GUCOMP  - Guam (1000x1000 @ 0.0085°, ~1 MB/frame)
#   CACOMP  - Canada (3560x1720 @ 0.025°, ~6 MB/frame)
#   OPERA   - Europe (3800x4400 @ 1km LAEA, ~16 MB/frame)
#
# Examples:
#   LIBREWXR_ENABLED_REGIONS=CONUS          (just continental US)
#   LIBREWXR_ENABLED_REGIONS=US             (all US regions)
#   LIBREWXR_ENABLED_REGIONS=EUROPE         (Europe only)
#   LIBREWXR_ENABLED_REGIONS=CANADA         (Canada only)
#   LIBREWXR_ENABLED_REGIONS=CONUS,EUROPE   (continental US + Europe)
#   LIBREWXR_ENABLED_REGIONS=ALL            (everything)
LIBREWXR_ENABLED_REGIONS=CONUS

# Data source for North American radar composites (USCOMP and CACOMP).
# Three modes, modeled after nowcast_blend_mode:
#
#   mrms_fallback  - (default) MRMS primary + IEM fallback for USCOMP + MSC
#                    blending for CACOMP.  Best coverage, slightly more bandwidth.
#                    MRMS covers 20-55°N, -130 to -60°W; MSC fills gaps in
#                    northern Canada and the Atlantic coast.  IEM is fetched
#                    only when MRMS fails for a specific frame.
#   mrms           - MRMS only, no fallback/blending.  Pure MRMS where available,
#                    gaps show as empty (IFS global fallback fills them in).
#                    Least bandwidth; good for verifying MRMS coverage alone.
#   iem            - Legacy IEM N0Q for USCOMP, MSC standalone for CACOMP.
#                    NEXRAD-only, no Canadian radar ingest.  Simplest and
#                    most battle-tested, but fewer radars and no QC.
LIBREWXR_NA_SOURCE=mrms_fallback

# Number of uvicorn worker processes. Each worker is a fully independent copy
# of LibreWXR with its own frame store, cache, and fetcher. More workers =
# better concurrency for simultaneous users, but each uses ~1.3 GB+ RAM
# (frames + tile cache). Scale workers first when handling more users.
#
# Scaling guide:
#   1       - Personal use / 1-5 users (~1.3 GB RAM)
#   2-4     - Small community / 5-50 users (~2.6-5.2 GB RAM)
#   4-8     - Medium traffic / 50-200 users (~5.2-10.4 GB RAM)
#   8+      - Large traffic / 200+ users (put nginx or a CDN in front too)
#
# Recommended: 1 worker per 2 CPU cores. For high traffic, a caching reverse
# proxy (nginx, CloudFlare) in front will help more than adding workers — tiles
# already set Cache-Control headers so any proxy can cache them automatically.
LIBREWXR_WORKERS=1

# Thread pool size for tile rendering. Controls two separate pools:
# one for direct tile requests and one for background warming (pre-rendering
# tiles for other timestamps so animation playback is smooth). Each pool
# gets this many threads. 0 = auto (CPU count - 1, minimum 1).
# On a 4-core machine, 3 is a good value (leaves 1 core for the event loop).
LIBREWXR_WARMER_THREADS=0

# Pre-warm coordinate caches up to this zoom level at startup.
# Coordinate caches store tile-to-region pixel index mappings; warming them
# eliminates cold-start latency from trigonometric projections. 0 = disabled.
# Each zoom level adds ~4x the tiles of the previous one (zoom 6 = ~5,500 tiles).
LIBREWXR_WARM_COORD_ZOOM=6

# Pre-render overview tiles up to this zoom level after each fetch cycle.
# Ensures zoomed-out views are served instantly from cache instead of
# on-demand rendering. -1 = disabled. At zoom 4, ~341 tiles per timestamp
# (total ~6,000 tiles for 18 timestamps), taking ~3-5s on 4-6 threads.
LIBREWXR_WARM_OVERVIEW_ZOOM=4

# Pre-render higher-zoom tiles ONLY where they overlap an enabled region's
# bounding box. Skips ocean / desert / unpopulated tiles that no one would
# zoom into, so high-zoom warming stays cheap. Applies to zoom levels above
# LIBREWXR_WARM_OVERVIEW_ZOOM up to and including this setting.
# -1 (or any value <= warm_overview_zoom) disables the regional pass.
# At zoom 6 with all regions enabled, the filter typically drops 80-85%
# of tiles, leaving ~600-900 tiles per timestamp instead of 5,120.
LIBREWXR_WARM_OVERVIEW_ZOOM_REGIONAL=6

# Number of ECMWF IFS hourly timesteps to fetch for global fallback animation.
# 0 = auto (recommended): derives from LIBREWXR_MAX_FRAMES so ECMWF animation
# covers the same time window as radar. Formula: ceil(max_frames / 6) + 1.
# At the default 10-min cadence:
#   12 frames (2h) → 3 timesteps, 18 (3h) → 4, 24 (4h) → 5
# Set to a positive number to override. Each timestep adds ~13 MB RAM and
# ~1-2 seconds to fetch time. Set to 1 for a static single snapshot.
# When ECMWF interpolation is enabled, each hourly pair also generates
# 5 synthetic 10-min frames (~130 MB total for the interpolated set).
LIBREWXR_ECMWF_MAX_TIMESTEPS=0

# Enable optical-flow interpolation of ECMWF IFS hourly data to 10-minute
# frames. Uses dense motion vectors to animate precipitation movement between
# IFS hours, so the global fallback animates smoothly like real radar data
# instead of jumping hour-to-hour.
# Adds ~130 MB RAM (for synthetic frames) and ~5-10s compute per IFS fetch.
# Set to false to disable (IFS will snap to nearest hour, visually jumpier).
LIBREWXR_ECMWF_INTERPOLATION=true

# ─── Regional NWP sources ────────────────────────────────────────────────
# LibreWXR composes its model layer from a chain of NWP sources, each
# covering a region.  The chain is built specificity-first: a regional
# high-res model fills its own domain, then ICON-EU fills the rest of
# Europe, then ECMWF IFS catches everything else globally.
# Soft-feathering at each domain edge prevents visible seams.

# North-American regional NWP source.
#   "ifs"  - (default) IFS only; no regional NWP over CONUS.
#   "hrrr" - NOAA HRRR-subh (3 km native LCC, 15-min subh frames, hourly
#            cycles, native composite reflectivity).  Anonymous AWS Open
#            Data — no auth or API key required.  Adds ~250 MB RAM for
#            the in-memory window.
LIBREWXR_NA_NWP_SOURCE=ifs

# HRRR publish delay: subh files typically arrive ~55 min after run init.
LIBREWXR_HRRR_PUBLISH_DELAY_MINUTES=55

# European NWP profile.  Each profile names the full set of European
# sources to instantiate; the resulting chain is logged at startup as
# "NWP chain: [...]" and surfaced at /health.
#   "ifs"               - (default) IFS only; no regional NWP over Europe.
#   "icon_eu_only"      - DWD ICON-EU (~7 km regridded lat/lon, hourly
#                         steps, 3-hourly cycles) ahead of IFS.  Free
#                         DWD opendata HTTPS — no auth.  Covers all of
#                         Europe broadly.
#   "dini_with_icon_eu" - DMI HARMONIE-AROME DINI (2 km native LCC,
#                         hourly steps, 3-hourly cycles) on top of
#                         ICON-EU on top of IFS.  Anonymous AWS Open
#                         Data S3.  DINI covers most of populated
#                         Europe (UK, France, Benelux, Germany, Alps,
#                         Czechia, Poland, southern Scandinavia,
#                         Iceland) at native 2 km; ICON-EU stays in the
#                         chain to fill Iberia, S. Italy, Greece, the
#                         Balkans, and eastern Europe past Poland.
#                         Adds ~250 MB RAM for the in-memory window.
LIBREWXR_EU_NWP_PROFILE=ifs

# ICON-EU publish delay: DWD main runs typically publish ~3-4h after
# init; 4h is the conservative default.
LIBREWXR_ICON_EU_PUBLISH_DELAY_MINUTES=240

# ICON-EU dBZ calibration shift applied after Marshall-Palmer Z-R
# conversion of the surface precipitation rate.  Radar reflectivity is
# sampled at the brightest part of the storm column and tends to read
# 5-10 dBZ higher than the surface rate would predict; +6 brings ICON-EU
# convective cells closer in colour to OPERA radar.
LIBREWXR_ICON_EU_DBZ_OFFSET=6.0

# DMI DINI publish delay: DMI files publish ~3 h after run init.
LIBREWXR_DMI_DINI_PUBLISH_DELAY_MINUTES=180

# DMI DINI dBZ calibration shift; same physics + same default as ICON-EU.
# Tune live against OPERA radar if convective cells read systematically
# too dim or bright.
LIBREWXR_DMI_DINI_DBZ_OFFSET=6.0

# Enable precipitation nowcasting (EXPERIMENTAL). Extrapolates recent radar
# forward using optical flow and blends with ECMWF IFS forecast, providing
# 60 minutes of short-range precipitation forecast. The blend transitions
# smoothly from radar-weighted (near-term) to IFS-weighted (far-term), with
# spatial feathering at radar coverage boundaries to prevent hard seams.
# Quality varies: works best for steady, organized precipitation; less
# reliable for fast-developing convection or cell initiation/dissipation.
# Adds ~120 MB RAM per frame × nowcast_frames for extrapolated data.
LIBREWXR_NOWCAST_ENABLED=true

# Nowcast blend mode: controls how radar extrapolation and the NWP model
# (HRRR over CONUS, IFS elsewhere) are combined during the first 60 min
# of the nowcast window.  Beyond 60 min, pure model is always used.
#   "blended" - smooth transition from radar-heavy to model-heavy
#               (~82% radar at T+10 min, fading to ~20% radar at T+60 min)
#   "radar"   - (default) pure radar extrapolation for the first 60 min
#               (closest to Rain Viewer behavior; less reliable for initiation)
#   "model"   - pure NWP forecast for all nowcast frames (most spatially
#               consistent but misses fine detail from recent radar)
LIBREWXR_NOWCAST_BLEND_MODE=radar

# Number of nowcast frames to generate. Each frame covers one fetch interval
# (default 10 min). At 10-min cadence: 6 frames = 60 min forecast.
# More frames = longer forecast range but lower accuracy at the far end.
# Rain Viewer offered ~30 min free / 60 min paid, so 6 is a good default.
LIBREWXR_NOWCAST_FRAMES=6

# Enable IFS-derived satellite (cloud cover) tiles. Fetches cloud_cover_high,
# cloud_cover_mid, and cloud_cover_low from the same ECMWF IFS data used for
# global precipitation fallback and composites them into a satellite-like
# infrared cloud layer. High clouds render bright white, mid clouds light
# gray, low clouds darker gray — approximating what IR satellite imagery shows.
# Global coverage with no additional data sources or API keys required.
LIBREWXR_SATELLITE_ENABLED=true

# Number of hourly IFS cloud cover timesteps to keep. Each timestep is one
# hour of the IFS model run. 12 = 12 hours of cloud cover animation.
# Each timestep adds ~20 MB RAM (three 3600x1801 uint8 grids).
LIBREWXR_SATELLITE_MAX_FRAMES=12

# Persistent cache directory for processed satellite grids. When set,
# cloud cover data is saved to disk as memory-mapped files so it survives
# restarts, crashes, and container recreation — no need to re-download
# from S3 on startup. Also reduces RAM by letting the OS page cache manage
# physical memory for satellite grids (~18.5 MB per timestep on disk).
# Empty/unset = in-memory only (data lost on restart).
# Docker: set via docker-compose.yml with a named volume (automatic).
# Local dev: set to a local path like ./cache.
LIBREWXR_CACHE_DIR=

# Tile request tracking. When enabled, per-tile request counts at z >= the
# tracked zoom are recorded in memory and surfaced in /health under
# `tile_requests`. Used to identify hotspots for a future adaptive
# pre-warming pass (see adaptive-tile-warming-design.md). Cheap on the hot
# path (one dict update per request); counters reset on restart.
LIBREWXR_TILE_TRACKING_ENABLED=true
LIBREWXR_TILE_TRACKING_MIN_ZOOM=7
LIBREWXR_TILE_TRACKING_MAX_ENTRIES=10000

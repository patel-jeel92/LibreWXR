# LibreWXR Configuration
#
# Copy this file to .env and adjust values as needed.  Every setting has
# a sensible default — you only need to set what you want to change.
#
# This file covers the settings most self-hosters will touch.  Advanced
# tuning (per-source publish delays, dBZ calibration offsets, source
# base URLs / S3 buckets, internal memory thresholds) is available via
# LIBREWXR_<SOURCE>_PUBLISH_DELAY_MINUTES, *_DBZ_OFFSET, *_BASE_URL,
# *_S3_BUCKET, etc.  See docs/configuration-reference.md or
# src/librewxr/config.py for the full list and defaults.
#
# ════════════════════════════════════════════════════════════════════════
#   Contents
# ════════════════════════════════════════════════════════════════════════
#
#   1.  Server & Networking
#   2.  Radar Data Sources
#   3.  Regional NWP Models
#   4.  ECMWF IFS (Global Base Layer)
#   5.  Precipitation Nowcasting
#   6.  Satellite Imagery (Cloud Cover)
#   7.  Weather Alerts (WMO CAP)
#   8.  Tile Rendering
#   9.  Workers & Memory
#  10.  Persistent Disk Cache
#  11.  Multi-Worker Deployment
#  12.  Diagnostics & Reliability
#
# ════════════════════════════════════════════════════════════════════════


# ════════════════════════════════════════════════════════════════════════
#   1. SERVER & NETWORKING
# ════════════════════════════════════════════════════════════════════════
# Where the server listens, what URL clients use to reach it, and how
# high they can zoom.

# Public-facing URL used in the weather-maps.json metadata response.
# Set this to whatever URL clients will use to reach your instance.
LIBREWXR_PUBLIC_URL=http://localhost:8080

# Port the server listens on.
LIBREWXR_PORT=8080

# Maximum tile zoom level (0-12).  Higher values allow more detail when
# zoomed in but use more memory for cached tiles.  12 is the max
# supported by the data sources.
LIBREWXR_MAX_ZOOM=12


# ════════════════════════════════════════════════════════════════════════
#   2. RADAR DATA SOURCES
# ════════════════════════════════════════════════════════════════════════
# Which radar composites to fetch and how often.  Each enabled region
# pulls a separate composite; turning regions off reduces RAM, network,
# and processing.

# Radar regions to fetch.  Use a group alias or comma-separated region
# codes.
#
# Group aliases:
#   CONUS            - Continental US only (default, lightest)
#   US               - All US regions (CONUS + Alaska, Hawaii, Puerto Rico, Guam)
#   CANADA           - Canada (ECCC MSC GeoMet WMS)
#   CENTRAL_AMERICA  - El Salvador + W. Honduras + S. Guatemala + offshore
#                      Pacific (MARN/SNET San Andrés, 120 km range)
#   EUROPE           - Europe (OPERA pan-European composite, ~155 radars,
#                      24 countries)
#   SOUTHEAST_ASIA   - Peninsular Malaysia + N. Sumatra + all of Borneo
#                      + Brunei (MET Malaysia peninsular + east
#                      composites, ~2 km / 10 min)
#   TAIWAN           - Taiwan + W. Pacific buffer (CWA QPESUMS 7-radar
#                      composite, 1.4 km observed dBZ)
#   ALL              - Every available region
#
# Individual regions (can mix with groups):
#   USCOMP  - Continental US        (~63 MB/frame)
#   AKCOMP  - Alaska                (~6 MB/frame)
#   HICOMP  - Hawaii                (~3.4 MB/frame)
#   PRCOMP  - Puerto Rico           (~1 MB/frame)
#   GUCOMP  - Guam                  (~1 MB/frame)
#   CACOMP  - Canada                (~6 MB/frame)
#   SVCOMP  - El Salvador region    (<1 MB/frame)
#   OPERA   - Europe (24 countries) (~16 MB/frame)
#   TWCOMP  - Taiwan + W. Pacific   (~3 MB/frame)
#   MYPENINSULAR - Peninsular Malaysia + N. Sumatra (MET Malaysia) (<1 MB/frame)
#   MYEAST       - East Malaysia (Borneo) + Brunei  (MET Malaysia) (<1 MB/frame)
#
# Examples:
#   LIBREWXR_ENABLED_REGIONS=CONUS,EUROPE   (continental US + Europe)
#   LIBREWXR_ENABLED_REGIONS=US             (all US regions)
#   LIBREWXR_ENABLED_REGIONS=ALL            (everything)
LIBREWXR_ENABLED_REGIONS=ALL

# Global radar-layer toggle.  When true (default), the regional radar
# fetchers below run as normal.  When false, every MRMS / IEM / MSC /
# OPERA / MARN / CWA / MMD provider is skipped at startup, no S3 / HTTP
# fetches happen, and the radar tile path returns no data.  The
# satellite layer (real-sat + IFS-derived cloud) continues working
# unchanged — useful for satellite-only deployments and for faster
# startup during development of non-radar features.
LIBREWXR_RADAR_ENABLED=true

# Master switch for the regional NWP chain — HRRR / HRRR-Alaska / HRDPS
# / AROME-OM family / DMI DINI / ICON-EU / WRF-SMN.  When false, the NWP
# chain collapses to ECMWF IFS only, keeping global precipitation, cloud
# cover, and simulated-satellite paths fully intact.  Useful for
# satellite-only or nowcast-only development where the regional download
# volume isn't worth waiting on.  Per-source toggles below still apply
# when this is true.
LIBREWXR_REGIONAL_NWP_ENABLED=true

# Master switch for the GMGSI satellite source — NOAA's hourly global
# IR + VIS mosaic.  When true (default), the /v2/satellite/... endpoint
# is backed by real satellite imagery composited from GOES-East,
# GOES-West, Meteosat-9, Meteosat-10, and Himawari-9.  When false, the
# endpoint returns 503 and the catalog's satellite.infrared array is
# empty (same pattern as LIBREWXR_RADAR_ENABLED).
LIBREWXR_GMGSI_ENABLED=true

# Per-channel GMGSI toggles.  LW backs the IR night side; VIS adds
# the daytime reflected-sunlight overlay with a natural sunrise/sunset
# crossfade at the terminator.  Disabling VIS while LW stays on
# degrades the composite to LW-only.
LIBREWXR_GMGSI_LW_ENABLED=true
LIBREWXR_GMGSI_VIS_ENABLED=true

# How many hours of GMGSI history to keep resident.  ~15 MB per channel
# per hour; 12h × 2 channels ≈ 360 MB.
LIBREWXR_GMGSI_RETENTION_HOURS=12

# US-side radar data source (USCOMP / AKCOMP / HICOMP / PRCOMP / GUCOMP).
# Canada-side is controlled independently by LIBREWXR_CA_SOURCE.
#   mrms_fallback  - (default) MRMS primary + IEM fallback on failure.
#                    Best coverage, slightly more bandwidth.
#   mrms           - MRMS only, no fallback.  Gaps fall through to the
#                    global ECMWF IFS layer.  Least bandwidth.
#   iem            - Legacy IEM N0Q.  NEXRAD-only.
LIBREWXR_NA_SOURCE=mrms_fallback

# Canada-side radar data source (CACOMP) — fully independent of
# LIBREWXR_NA_SOURCE.  Mix any US choice with any Canada choice.
#   mrms_with_msc_blend - (default) MRMS primary covering southern Canada,
#                         MSC Canada blended in to fill gaps north of
#                         MRMS's bbox, MSC fallback if MRMS fails.
#                         Best coverage.
#   mrms                - MRMS only via the CONUS product.  Southern
#                         Canada covered; northern Canada (outside MRMS
#                         bbox) falls through to IFS.  No MSC fetched.
#   msc                 - MSC Canada standalone (native ECCC composite
#                         covering all of Canada).  No MRMS contribution
#                         to CACOMP.
LIBREWXR_CA_SOURCE=mrms_with_msc_blend

# How often (in seconds) to fetch new radar frames.  600 s (10 min) is
# the default cadence, matching Rain Viewer.  Frame timestamps are
# always aligned to clock boundaries (e.g. :00, :10, :20) regardless of
# when the server starts.  Most upstream sources publish every 2-5 min,
# so 300 is the practical lower bound for higher temporal resolution.
LIBREWXR_FETCH_INTERVAL=600

# Number of radar frames to keep in memory.  At the default 10-min
# cadence: 12 frames = 2 hours, 18 = 3 hours, 24 = 4 hours.  More
# frames = longer animation history at the cost of more RAM
# (~96 MB/frame with all regions enabled).
LIBREWXR_MAX_FRAMES=12


# ════════════════════════════════════════════════════════════════════════
#   3. REGIONAL NWP MODELS
# ════════════════════════════════════════════════════════════════════════
# LibreWXR composes its model layer from a chain of regional NWP
# sources, each covering a region.  The chain is built specificity-
# first: a regional high-res model fills its own domain, then a wider
# regional model fills its remainder, then ECMWF IFS catches everything
# else globally.  Soft feathering at each domain edge prevents visible
# seams.
#
# Each toggle below adds one model to the chain.  See section 4 for the
# global IFS layer that catches what's left.

# ─── North America: NOAA HRRR ────────────────────────────────────────
# Bundles HRRR-CONUS + HRRR-Alaska under a single toggle (same model,
# disjoint domains, same anonymous AWS Open Data bucket).
#   "ifs"  - (default) IFS only; no regional NWP over CONUS or Alaska.
#   "hrrr" - NOAA HRRR — bundles both domains:
#            * HRRR-CONUS  (3 km LCC, 15-min subh, hourly cycles)
#            * HRRR-Alaska (3 km polar stereo, hourly wrfsfcf,
#                           3-hourly cycles)
#            Adds ~280 MB RAM.
LIBREWXR_NA_NWP_SOURCE=hrrr

# ─── Canada: ECCC HRDPS-Continental ───────────────────────────────────
# 2.5 km rotated lat/lon.  Anonymous HTTPS via dd.weather.gc.ca.
# 4 cycles/day, 48 h horizon, hourly steps.  Covers Canada + the
# northern fringe of CONUS.  Adds ~150 MB RAM.
LIBREWXR_HRDPS_ENABLED=true

# ─── Europe: DMI DINI + DWD ICON-EU ──────────────────────────────────
# Each profile names the full set of European sources to instantiate;
# the resulting chain is logged at startup as "NWP chain: [...]" and
# surfaced at /health.
#   "ifs"               - (default) IFS only; no regional NWP over
#                         Europe.
#   "icon_eu_only"      - DWD ICON-EU (~7 km, hourly steps, 3-hourly
#                         cycles) ahead of IFS.  Free DWD opendata —
#                         no auth.
#   "dini_with_icon_eu" - DMI HARMONIE-AROME DINI (2 km native LCC,
#                         hourly steps, 3-hourly cycles) ahead of
#                         ICON-EU ahead of IFS.  Anonymous AWS Open
#                         Data S3.  DINI covers most of populated
#                         Europe at 2 km; ICON-EU stays in the chain
#                         to fill Iberia, S. Italy, Greece, the
#                         Balkans, and eastern Europe past Poland.
#                         Adds ~250 MB RAM total.
LIBREWXR_EU_NWP_PROFILE=dini_with_icon_eu

# ─── Caribbean: Météo-France AROME Antilles ──────────────────────────
# 1.3 km native.  Anonymous HTTPS on the OVH Swift bucket (Météo-France
# migrated PNT distribution off object.data.gouv.fr around 2026-01).
# 4 cycles/day, 48 h horizon, hourly steps.  Tiny in-memory cost
# (~10 MB) — the domain is small.
LIBREWXR_AROME_ANTILLES_ENABLED=true

# ─── Météo-France AROME Outre-Mer (the rest of the family) ──────────
# Same upstream + format + decoder as Antilles via the shared AROME
# overseas base class.  Each covers a different French overseas
# territory; all four are independently toggleable.
#
# GUYANE — French Guiana (~1100×880 km).  Pairs with the Caribbean
# AROME Antilles to give continuous coverage across the Lesser
# Antilles → Guianas arc.
LIBREWXR_AROME_GUYANE_ENABLED=true
# INDIEN — Réunion + Mayotte + Comoros + most of Madagascar + adjacent
# SW Indian Ocean (~3700×2500 km — the largest AROME-OM grid, ~70 MB
# RAM).
LIBREWXR_AROME_INDIEN_ENABLED=true
# NCALED — Nouvelle-Calédonie + adjacent SW Pacific (~1350×1350 km).
LIBREWXR_AROME_NCALED_ENABLED=true
# POLYN — French Polynesia (Society, Tuamotu, Marquesas archipelagoes,
# ~1350×1400 km).
LIBREWXR_AROME_POLYN_ENABLED=true

# ─── South American Cone: SMN Argentina WRF-DET ──────────────────────
# 4 km LCC — covers Argentina, Chile, Uruguay, Paraguay, Bolivia,
# southern Brazil + adjacent oceans.  Anonymous AWS Open Data S3.
# 4 cycles/day, 72 h horizon, NetCDF4 files (~34 MB each).  Adds
# ~30-50 MB RAM.
LIBREWXR_WRF_SMN_ENABLED=true

# ─── Optical-flow temporal interpolation ────────────────────────────
# Same Farneback dense-flow technique we use on ECMWF IFS hourly
# frames, applied to every regional NWP source whose native cadence
# is hourly (WRF-SMN, DMI DINI, ICON-EU — others as they're added).
# Without this, a moving precip cell appears to cross-fade between
# hourly bracket frames at intermediate query times, producing a
# visible "two faint copies" ghost.  With it, the cell translates
# smoothly along motion vectors.  Adds ~2-10 s of CPU per source
# per fetch cycle (smallest grid ~2 s, largest ~10 s).  Snow masks
# ride alongside precip through the same interpolation step.
LIBREWXR_REGIONAL_INTERPOLATION=true

# ─── Native snow/rain classification threshold ──────────────────────
# Temperature cutoff for the regional NWP snow masks (HRRR-CONUS,
# HRRR-Alaska, WRF-SMN, DMI DINI, ICON-EU all derive a snow mask
# from their own 2-metre temperature field; HRDPS and AROME Antilles
# fall through to ECMWF IFS for snow detection).  Pixels colder than
# this are tagged as snow.  1.5 °C is a typical near-surface snow-vs-
# rain transition; drop towards 0 °C for a stricter "only true
# freezing" definition; raise to 2-3 °C to catch wet snow / sleet
# that visually behaves like snow on the ground.
LIBREWXR_REGIONAL_SNOW_TEMP_THRESHOLD=1.5

# ─── Fetch concurrency ───────────────────────────────────────────────
# Maximum number of NWP grid fetches running in parallel inside one
# fetch cycle.  Each grid loads tens-to-hundreds of MB during decode,
# so this caps peak transient RAM at ~N × per-grid working set.
# 4 fits comfortably in 8 GB; bump to 6-8 on bigger rigs to bring
# cycle wall time closer to the slowest single source.  The
# multi-worker compose file overrides this to 8 by default.
LIBREWXR_NWP_FETCH_CONCURRENCY=4


# ════════════════════════════════════════════════════════════════════════
#   4. ECMWF IFS — GLOBAL BASE LAYER
# ════════════════════════════════════════════════════════════════════════
# IFS is the global base of the NWP chain.  It provides precipitation
# animation everywhere the regional models in section 3 don't reach,
# drives the satellite cloud layer (section 6), and powers nowcast
# extrapolation outside regional coverage.

# Disable ECMWF IFS entirely.  Useful only for isolating regional NWP
# layers during debugging — anywhere outside the regional models will
# then simply show zero precipitation and no satellite cloud.
LIBREWXR_ECMWF_ENABLED=true

# Enable optical-flow interpolation of ECMWF IFS hourly data to 10-min
# frames.  Adds ~130 MB RAM and ~5-10 s compute per IFS fetch.  Disable
# for jumpier hour-to-hour animation but lower CPU/RAM cost.
LIBREWXR_ECMWF_INTERPOLATION=true

# Number of ECMWF IFS hourly timesteps to fetch.  0 = auto
# (recommended): derived from LIBREWXR_MAX_FRAMES + nowcast window so
# the IFS animation covers the same time span as radar.  Set
# explicitly to override.
LIBREWXR_ECMWF_MAX_TIMESTEPS=0


# ════════════════════════════════════════════════════════════════════════
#   5. PRECIPITATION NOWCASTING
# ════════════════════════════════════════════════════════════════════════
# Short-range precipitation forecast (EXPERIMENTAL).  Extrapolates
# recent radar forward using optical flow, optionally blended with the
# active NWP model from the chain — HRRR over CONUS, HRDPS over
# Canada, ICON-EU/DINI over Europe, AROME Antilles over the Caribbean,
# WRF-SMN over the S. American Cone, IFS everywhere else.

# Enable nowcasting.  Quality varies: works best for steady, organized
# precipitation; less reliable for fast-developing convection or cell
# initiation / dissipation.
LIBREWXR_NOWCAST_ENABLED=true

# Nowcast blend mode for the first 60 min of the nowcast window.
# Beyond 60 min, pure model is always used.
#   "radar"   - pure radar extrapolation (closest to Rain Viewer
#               behaviour; visibly diverges from reality past ~30 min
#               for fast-moving convection)
#   "blended" - (default) smooth radar → model transition (~82% radar
#               at T+10, fading to ~20% radar at T+60).  Leverages the
#               regional NWP chain (HRRR / HRDPS / DMI DINI / ICON-EU
#               / AROME / WRF-SMN / IFS) for the far end of the window
#   "model"   - pure NWP forecast (most spatially consistent, misses
#               fine detail from recent radar)
LIBREWXR_NOWCAST_BLEND_MODE=blended

# Number of nowcast frames to generate.  At 10-min cadence, 6 frames
# = 60 min forecast.  More frames = longer range, lower far-end
# accuracy.
LIBREWXR_NOWCAST_FRAMES=6


# ════════════════════════════════════════════════════════════════════════
#   6. SATELLITE IMAGERY (CLOUD COVER)
# ════════════════════════════════════════════════════════════════════════
# IFS-derived IR-like cloud tiles that populate the Rain Viewer-
# compatible satellite.infrared endpoint.

# Enable IFS-derived satellite tiles.  Composites cloud_cover_high,
# cloud_cover_mid, and cloud_cover_low from the same ECMWF IFS data
# into an IR-like cloud layer.  Global coverage, no extra data
# sources.
LIBREWXR_SATELLITE_ENABLED=true

# Hourly IFS cloud cover timesteps to keep.  12 = 12 hours of
# animation.  Each timestep adds ~20 MB RAM (three 3600×1801 uint8
# grids).
LIBREWXR_SATELLITE_MAX_FRAMES=12


# ════════════════════════════════════════════════════════════════════════
#   7. WEATHER ALERTS (WMO CAP)
# ════════════════════════════════════════════════════════════════════════
# Global weather alerts polled from severeweather.wmo.int, plus the
# NWS point endpoint for US locations (surfaces non-polygon alerts
# like Tornado Watches).  MeteoAlarm geocodes are downloaded on first
# startup and cached locally.  Updates are clock-aligned
# (:00, :05, :10, …).

# Enable the alerts API.  When off, /v2/alerts returns 503.
LIBREWXR_ALERTS_ENABLED=true

# How often (in seconds) to refresh alerts.  300 s (5 min) matches the
# upstream update cadence; 600 s halves the request volume.
LIBREWXR_ALERTS_FETCH_INTERVAL=300

# Max concurrent HTTP connections when polling the WMO endpoints.
LIBREWXR_ALERTS_CONCURRENCY=5


# ════════════════════════════════════════════════════════════════════════
#   8. TILE RENDERING
# ════════════════════════════════════════════════════════════════════════
# How rendered radar tiles look, how big the caches are, and how much
# is pre-rendered after each fetch cycle.  All cache sizes are
# per-worker.

# ─── Cache sizes ─────────────────────────────────────────────────────

# Maximum tile cache size in megabytes per worker.  Oldest entries are
# evicted when this byte limit is reached.  Higher = faster tile
# serving, lower = less RAM usage.  The multi-worker compose file
# drops this to 64 MB per worker since many workers share the rack.
LIBREWXR_TILE_CACHE_MB=200

# Coordinate cache size: max entries per coordinate LRU cache (one
# cache per region/size combination).  Each entry is 0.5-2 MB.  Lower
# saves RAM at the cost of occasional ~5-20 ms recomputation on miss.
# The multi-worker compose file drops this to 256 per worker.
LIBREWXR_COORD_CACHE_SIZE=2048

# ─── Image filters ───────────────────────────────────────────────────

# Baseline Gaussian blur radius for tile smoothing (when smooth=1 in
# the tile URL).  The renderer auto-scales this up at high zoom for
# coarse sources (OPERA, MRMS, MMD, etc.) by inspecting how many tile
# pixels each region pixel covers — so this value sets the floor, not
# the cap.  0 = disable smoothing entirely.
LIBREWXR_SMOOTH_RADIUS=1.0

# Minimum dBZ threshold to display.  Pixels below this are made
# transparent.  Filters out ground clutter and weak noise.  Set to
# -32 to show everything.
LIBREWXR_NOISE_FLOOR_DBZ=10.0

# Speckle filter: minimum non-zero neighbors (out of 8) a pixel must
# have to be kept.  0 = disabled, 3 = moderate (recommended),
# 4+ = aggressive.
LIBREWXR_DESPECKLE_MIN_NEIGHBORS=3

# WebP encoding quality.  100 = lossless, 65 = lossy (visually
# identical for radar, ~4-6× smaller than PNG).  Only affects
# WebP-format tiles.
LIBREWXR_WEBP_QUALITY=65

# ─── Pre-warming ─────────────────────────────────────────────────────

# Thread pool size for tile rendering, per worker.  0 = auto (CPU
# count - 1, minimum 1).  On a 4-core machine, 3 leaves one core for
# the event loop.  The multi-worker compose file drops this to 4 per
# worker to avoid oversubscribing the rack.
LIBREWXR_WARMER_THREADS=0

# Pre-warm coordinate caches up to this zoom level at startup.
# Eliminates cold-start latency from trigonometric projections.
# 0 = disabled.
LIBREWXR_WARM_COORD_ZOOM=6

# Pre-render overview tiles up to this zoom level after each fetch
# cycle.  -1 = disabled.  At zoom 4, ~341 tiles per timestamp.
LIBREWXR_WARM_OVERVIEW_ZOOM=4

# Pre-render higher-zoom tiles ONLY where they overlap an enabled
# region's bounding box.  Skips ocean / desert / unpopulated tiles.
# Applies between LIBREWXR_WARM_OVERVIEW_ZOOM (exclusive) and this
# value (inclusive).  -1 (or <= warm_overview_zoom) disables the
# regional pass.
LIBREWXR_WARM_OVERVIEW_ZOOM_REGIONAL=6


# ════════════════════════════════════════════════════════════════════════
#   9. WORKERS & MEMORY
# ════════════════════════════════════════════════════════════════════════
# How many uvicorn workers to run and how memory is capped.  For
# splitting fetch from render across containers, see section 11
# (multi-worker deployment).

# ─── Worker count ────────────────────────────────────────────────────

# Number of uvicorn worker processes.
#
# Single-process mode (docker-compose.yml): each worker is a fully
# independent copy of LibreWXR with its own frame store, caches, and
# fetcher.  More workers = more concurrency at ~1.3 GB+ RAM each.
# Recommended: 1 worker per 2 CPU cores; put a caching proxy (nginx,
# Cloudflare) in front for high traffic.
#
# Multi-worker mode (docker-compose.multiworker.yml): workers share
# radar / NWP / cloud state via memmap-backed snapshots written by a
# sidecar data-pipeline process.  Scale workers across many cores
# without the per-worker data-RAM cost.  See section 11.
LIBREWXR_WORKERS=1

# ─── Memory caps ─────────────────────────────────────────────────────

# Container memory limit in MB for the in-process memory pressure
# monitor.  0 = auto-detect from Docker / cgroup, falling back to
# system RAM.
LIBREWXR_MEMORY_LIMIT_MB=0

# Docker container memory caps (used by the compose files).
#
# Single-container deployment (docker-compose.yml):
#   LIBREWXR_MEMORY      = total cap on the single librewxr container
#                          (default 7G — sized for ALL regions +
#                          1 worker)
#
# Multi-worker deployment (docker-compose.multiworker.yml):
#   LIBREWXR_PIPELINE_MEMORY = cap on the data-pipeline container
#                              (default 12G — sized for all NWP
#                              sources plus parallel-fetch headroom)
#   LIBREWXR_RENDER_MEMORY   = cap on the render container with N
#                              workers (default 18G — sized for 32
#                              workers sharing the page-cache-backed
#                              memmap snapshot)
#
# Production observation on an 80-core / 32 GB rack with multi-worker:
# total RSS settles around ~16 GB across both containers.
#LIBREWXR_MEMORY=7G
#LIBREWXR_PIPELINE_MEMORY=12G
#LIBREWXR_RENDER_MEMORY=18G


# ════════════════════════════════════════════════════════════════════════
#   10. PERSISTENT DISK CACHE
# ════════════════════════════════════════════════════════════════════════
# Where processed grids (NWP, satellite, alerts geocodes, master state
# snapshot) live on disk so they survive restarts.  Required for
# multi-worker mode (section 11).

# Cache directory for processed grids.  When set, data is saved as
# memory-mapped files that survive restarts, crashes, and container
# recreation.  Empty = in-memory only (everything re-downloaded on
# startup).
#
# REQUIRED in multi-worker mode (both the pipeline and render
# containers must share this directory via a named volume).
#
# Docker: set automatically via a named volume (see compose files).
# Local dev: set to a local path like ./cache.
LIBREWXR_CACHE_DIR=


# ════════════════════════════════════════════════════════════════════════
#   11. MULTI-WORKER DEPLOYMENT
# ════════════════════════════════════════════════════════════════════════
# Runs the data pipeline (python -m librewxr.data_pipeline) as a
# sidecar process and N tile-server worker processes alongside it,
# all sharing CACHE_DIR via memmap files + a single state.json
# snapshot.  Bypasses Python's GIL on the tile-render path so the
# rack's full core count can actually do work.
#
# To enable:
#   1. Set LIBREWXR_CACHE_DIR (section 10) to a shared directory.
#   2. Use docker-compose.multiworker.yml, or run the two processes
#      manually:
#        $ python -m librewxr.data_pipeline        # sidecar
#        $ LIBREWXR_RENDER_ONLY=1 LIBREWXR_WORKERS=N \
#          python -m librewxr.main                 # tile server
#
# When render_only is true, the worker skips fetcher / NWP grid /
# cloud / nowcast initialisation entirely — it only renders tiles
# from the snapshot the pipeline writes.

# Flip to true on the tile-server side in a multi-worker deployment.
LIBREWXR_RENDER_ONLY=false

# Seconds between state.json mtime polls in render-only mode.  The
# pipeline rewrites state.json once per fetch_interval (default
# 600 s), so 1 s polls are responsive without burning CPU.
LIBREWXR_STATE_POLL_INTERVAL=1.0

# Seconds for render workers to wait for the first state.json on
# cold start before failing loudly.  0 = wait forever.
LIBREWXR_STATE_WAIT_TIMEOUT=300


# ════════════════════════════════════════════════════════════════════════
#   12. DIAGNOSTICS & RELIABILITY
# ════════════════════════════════════════════════════════════════════════
# Observability hooks and resilience tuning.  None of this changes
# the data you serve — just how you can see into the running server
# and how it handles transient upstream failures.

# Per-tile request counts at high zooms are recorded in memory and
# surfaced in /health under `tile_requests`.  Useful for spotting
# traffic hotspots; cheap on the hot path; counters reset on
# restart.
LIBREWXR_TILE_TRACKING_ENABLED=true

# Number of retries on transient download errors (connection refused,
# timeout, DNS failure, truncated response).  0 = fail immediately,
# 1 = one retry.  Applies to every data source (radar, NWP,
# satellite, alerts).  Each retry waits 1 second before trying
# again.
LIBREWXR_DOWNLOAD_RETRIES=1
